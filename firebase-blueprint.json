{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "worker", "listener", "coordinator"] },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "classification": { "type": "string" },
        "specialty": { "type": "string" },
        "avatar": { "type": "string" },
        "mobile": { "type": "string" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "permissions": {
          "type": "object",
          "properties": {
            "canEditNews": { "type": "boolean" },
            "canEditProgramming": { "type": "boolean" },
            "canEditAbout": { "type": "boolean" },
            "canEditCatalog": { "type": "boolean" },
            "canEditFichas": { "type": "boolean" },
            "canEditHours": { "type": "boolean" },
            "canEditTeam": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "username", "role", "email"]
    },
    "GeneratedAgenda": {
      "title": "Generated PDF Agenda",
      "description": "Metadata for a PDF agenda generated by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "filename": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "month": { "type": "string" },
        "weekLabel": { "type": "string" },
        "authorId": { "type": "string" },
        "pdfData": { "type": "string", "description": "Base64 encoded PDF or storage reference" }
      },
      "required": ["id", "filename", "createdAt", "authorId"]
    },
    "EditorialContent": {
      "title": "Editorial Content",
      "description": "Real-time content for the agenda programs",
      "type": "object",
      "properties": {
        "programId": { "type": "string" },
        "weekId": { "type": "string" },
        "dayName": { "type": "string" },
        "month": { "type": "string" },
        "theme": { "type": "string" },
        "ideas": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and global staff data"
    },
    "/generated_agendas/{agendaId}": {
      "schema": "GeneratedAgenda",
      "description": "History of generated PDF agendas shared across the team"
    },
    "/editorial_contents/{contentId}": {
      "schema": "EditorialContent",
      "description": "Real-time sync for agenda themes and ideas"
    }
  }
}
